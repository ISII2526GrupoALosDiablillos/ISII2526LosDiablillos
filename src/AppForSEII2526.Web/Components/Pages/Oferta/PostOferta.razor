@page "/oferta/createoferta"

@using System.Linq
@using System.Net
@using System.Net.Http.Json
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API

@inject NavigationManager navigation
@inject ILogger<PostOferta> logger
@inject OfertaStateContainer ofertaState
@inject AppForSEII2526APIClient apiclient
@inject HttpClient Http

<h3>Crear Oferta</h3>

<EditForm Model="oferta" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>

    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <div class="form-floating">
                <InputDate @bind-Value="oferta.FechaInicio" class="form-control" id="FechaInicio" />
                <label for="FechaInicio">Fecha de Inicio</label>
            </div>
        </div>

        <div class="col-12">
            <div class="form-floating">
                <InputDate @bind-Value="oferta.FechaFinal" class="form-control" id="FechaFinal" />
                <label for="FechaFinal">Fecha Final </label>
            </div>
        </div>

        <div class="col-12">
            <div class="form-floating">
                <InputSelect class="form-select" @bind-Value="MetodoPagoSeleccionado" id="tiposMetodoPago">
                    @foreach (var m in Enum.GetValues(typeof(TiposMetodoPago)).Cast<TiposMetodoPago>())
                    {
                        <option value="@((int)m)">@m.ToString()</option>
                    }
                </InputSelect>
                <label for="TipoMetodoPago">Método de Pago</label>
            </div>
        </div>

        <div class="col-12">
            <div class="form-floating">
                <InputSelect class="form-select" @bind-Value="DirigidaOfertaSeleccionada" id="DirigidaOferta">
                    @foreach (var d in Enum.GetValues(typeof(TiposDirigidaOferta)).Cast<TiposDirigidaOferta>())
                    {
                        <option value="@((int)d)">@d.ToString()</option>
                    }
                </InputSelect>
                <label for="TipoDirigidaOferta">Dirigida a</label>
            </div>
        </div>

        <div class="col-12">
            <div class="form-floating">
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@(oferta.OfertaItems.Count == 0)">
                    Oferta tus herramientas
                </button>
            </div>
        </div>
    </div>

    <br />
    <br />

    <h4>Resumen de la Oferta</h4>
    <p><b>Desde:</b> @oferta.FechaInicio.ToString("dd/MM/yyyy") <b>hasta:</b> @oferta.FechaFinal.ToString("dd/MM/yyyy")</p>
    <p><b>Precio total:</b> @PrecioTotal.ToString("0.00") €</p>

    <button class="btn btn-outline-primary" type="button" @onclick="ModifyOfertaItems" id="ModifyHerramientas">
        Modificar / Añadir Herramientas
    </button>

    <div class="mh-100 table-responsive mt-3">
        <table class="table table-condensed table-hover" id="TableOfOfertaItems">
            <thead>
                <tr>
                    <th>ID Herramienta</th>
                    <th>Precio Base</th>
                    <th>Descuento (%)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in oferta.OfertaItems)
                {
                    <tr id="HerramientaData_@item.HerramientaId">
                        <td>@item.HerramientaId</td>
                        <td>@item.PrecioFinal.ToString("0.00") €</td>
                        <td>
                            <InputNumber @bind-Value="item.Porcentaje"
                                         class="form-control"
                                         id="@($"porcentaje_{item.HerramientaId}")" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Confirmar Oferta"
            Message="¿Quieres publicar esta oferta con las herramientas seleccionadas?"
            OnClose="@OnDialogClose"
            Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors => messageError.Length == 0;
    private bool DialogIsOpen;

    private OfertaForCreateDTO oferta => ofertaState.Oferta;

    private int MetodoPagoSeleccionado { get; set; }
    private int DirigidaOfertaSeleccionada { get; set; }

    private float PrecioTotal
    {
        get
        {
            // OJO: aquí asumimos que item.PrecioFinal es el precio base (como lo estás mostrando en tabla)
            return (float)oferta.OfertaItems.Sum(ri => ri.PrecioFinal * (100f - (float)ri.Porcentaje) / 100f);
        }
    }

    protected override void OnInitialized()
    {
        MetodoPagoSeleccionado = (int)oferta.MetodoPago;
        DirigidaOfertaSeleccionada = (int)oferta.DirigidaOferta;
    }

    private void ModifyOfertaItems()
    {
        oferta.MetodoPago = (TiposMetodoPago)MetodoPagoSeleccionado;
        oferta.DirigidaOferta = (TiposDirigidaOferta)DirigidaOfertaSeleccionada;
        navigation.NavigateTo("/oferta/selectherramientaparaoferta");
    }

    private void OpenDialog()
    {
        messageError = "";

        if (oferta.OfertaItems.Count == 0)
        {
            messageError = "No hay herramientas en la oferta.";
            return;
        }

        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if (!isOk) return;

        try
        {
            // Mantener enums en el state
            oferta.MetodoPago = (TiposMetodoPago)MetodoPagoSeleccionado;
            oferta.DirigidaOferta = (TiposDirigidaOferta)DirigidaOfertaSeleccionada;

            if (oferta.OfertaItems.Count == 0)
            {
                messageError = "No hay herramientas en la oferta.";
                return;
            }

            // IMPORTANTE: en tu DTO el Porcentaje tiene [Range(0.01, 99.99)]
            foreach (var item in oferta.OfertaItems)
                if (item.Porcentaje <= 0) item.Porcentaje = 0.01;

            // Creamos un DTO a enviar SIN “machacar” el state (evita doble descuento si reintentas)
            var dto = new OfertaForCreateDTO
            {
                FechaInicio = oferta.FechaInicio,
                FechaFinal = oferta.FechaFinal,
                FechaOferta = DateTime.Now,
                MetodoPago = oferta.MetodoPago,
                DirigidaOferta = oferta.DirigidaOferta,
                OfertaItems = oferta.OfertaItems.Select(i => new OfertaItemForCreateDTO
                {
                    HerramientaId = i.HerramientaId,
                    Porcentaje = i.Porcentaje,
                    // aquí calculamos el precio final aplicando descuento a tu “precio base”
                    PrecioFinal = Math.Round(i.PrecioFinal * (1.0 - (i.Porcentaje / 100.0)), 2)
                }).ToList()
            };

            // POST manual para poder leer la cabecera Location
            var url = BuildCreateOfertaUrl();
            var resp = await Http.PostAsJsonAsync(url, dto);

            if (resp.IsSuccessStatusCode)
            {
                // Location debería ser algo como: /api/OfertaItem/Oferta-Detalle/123
                var location = resp.Headers.Location?.ToString();

                if (!string.IsNullOrWhiteSpace(location) && TryExtractIdFromLocation(location, out var id))
                {
                    ofertaState.OfertaProcessed();
                    navigation.NavigateTo($"/oferta/detalleoferta?ofertaId={id}");
                    return;
                }

                // Si por lo que sea no viene Location, al menos vas al detalle “manual”
                ofertaState.OfertaProcessed();
                navigation.NavigateTo("/oferta/detalleoferta");
                return;
            }

            // 400 -> intentamos leer ValidationProblemDetails
            if (resp.StatusCode == HttpStatusCode.BadRequest)
            {
                var vpd = await resp.Content.ReadFromJsonAsync<AppForSEII2526.Web.API.ValidationProblemDetails>();
                if (vpd?.Errors?.Values != null)
                {
                    messageError = "";
                    foreach (var errs in vpd.Errors.Values)
                        messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errs));
                    return;
                }
            }

            // Otros errores
            messageError = $"Error ({(int)resp.StatusCode}): {await resp.Content.ReadAsStringAsync()}";
        }
        catch (Exception ex)
        {
            messageError = "Error inesperado: " + ex.Message;
        }
    }

    private string BuildCreateOfertaUrl()
    {
        // Endpoint real según tu controller:
        // [Route("api/[controller]")] => api/OfertaItem
        // [Route("[action]")] => CreateOferta
        var baseUrl = (apiclient.BaseUrl ?? "").TrimEnd('/');

        if (string.IsNullOrWhiteSpace(baseUrl))
            return "api/OfertaItem/CreateOferta";

        if (baseUrl.EndsWith("/api", StringComparison.OrdinalIgnoreCase))
            return $"{baseUrl}/OfertaItem/CreateOferta";

        return $"{baseUrl}/api/OfertaItem/CreateOferta";
    }

    private static bool TryExtractIdFromLocation(string location, out int id)
    {
        id = 0;

        try
        {
            // Location puede ser absoluta o relativa
            Uri uri;
            if (Uri.TryCreate(location, UriKind.Absolute, out var abs))
                uri = abs;
            else
                uri = new Uri("http://dummy" + (location.StartsWith("/") ? location : "/" + location));

            var last = uri.Segments.LastOrDefault()?.Trim('/');
            return int.TryParse(last, out id);
        }
        catch
        {
            return false;
        }
    }
}
